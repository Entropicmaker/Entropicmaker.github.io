---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="project-card">
  <div class="project-card-head">
    <span class="project-index" aria-hidden="true">◫</span>
    <span class="status-badge">{project.status}</span>
  </div>
  <p class="eyebrow">{project.category} · {project.year}</p>
  <h3>{project.title}</h3>
  <p>{project.description}</p>
  <p class="project-outcome"><strong>阶段结果</strong>{project.outcome}</p>
  <ul class="tech-list" aria-label="项目技术栈">
    {project.stack.map((item) => <li>{item}</li>)}
  </ul>
</article>
