---
import { navigation, siteConfig } from '../data/site';
import { withBase } from '../utils/site';

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  const target = withBase(href);
  return href === '/' ? currentPath === target : currentPath.startsWith(target);
};
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand" href={withBase('/')} aria-label={`${siteConfig.name}首页`}>
      <span class="brand-mark" aria-hidden="true">⌖</span>
      <span>{siteConfig.name}</span>
    </a>
    <nav class="desktop-nav" aria-label="主导航">
      {
        navigation.map((item) => (
          <a href={withBase(item.href)} aria-current={isActive(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="header-actions">
      <a class="icon-button search-button" href={withBase('/search/')} aria-label="搜索文章">
        <span aria-hidden="true">⌕</span>
      </a>
      <button class="icon-button" id="theme-toggle" type="button" aria-label="切换深浅色模式">
        <span class="theme-icon" aria-hidden="true">◐</span>
      </button>
      <button
        class="icon-button menu-button"
        id="menu-toggle"
        type="button"
        aria-label="打开导航菜单"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span aria-hidden="true">☰</span>
      </button>
    </div>
  </div>
  <nav class="mobile-nav shell" id="mobile-nav" aria-label="移动端导航" hidden>
    {navigation.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
    <a href={withBase('/search/')}>搜索</a>
  </nav>
</header>

<script>
  const themeButton = document.querySelector<HTMLButtonElement>('#theme-toggle');
  themeButton?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    localStorage.setItem('theme', next);
    themeButton.setAttribute('aria-label', next === 'dark' ? '切换到浅色模式' : '切换到深色模式');
  });

  const menuButton = document.querySelector<HTMLButtonElement>('#menu-toggle');
  const mobileNav = document.querySelector<HTMLElement>('#mobile-nav');
  menuButton?.addEventListener('click', () => {
    if (!mobileNav) return;
    const willOpen = mobileNav.hidden;
    mobileNav.hidden = !willOpen;
    menuButton.setAttribute('aria-expanded', String(willOpen));
    menuButton.setAttribute('aria-label', willOpen ? '关闭导航菜单' : '打开导航菜单');
  });
</script>
