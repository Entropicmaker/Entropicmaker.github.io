---
import type { Post } from '../utils/posts';
import { formatDate, getCategory, getPostUrl, getReadingTime, tagToSlug } from '../utils/posts';
import { withBase } from '../utils/site';

interface Props {
  post: Post;
  compact?: boolean;
}

const { post, compact = false } = Astro.props;
const category = getCategory(post.data.category);
---

<article class:list={['post-card', { compact }]}>
  <div class="post-card-topline">
    <a class="category-chip" href={withBase(`/categories/${post.data.category}/`)}
      >{category.name}</a
    >
    <span>{formatDate(post.data.pubDate)}</span>
  </div>
  <h3><a href={withBase(getPostUrl(post))}>{post.data.title}</a></h3>
  {!compact && <p>{post.data.description}</p>}
  <div class="post-card-meta">
    {post.data.subcategory && <span>{post.data.subcategory}</span>}
    {post.data.series && <span>系列：{post.data.series}</span>}
    <span>{getReadingTime(post)} 分钟</span>
  </div>
  {
    !compact && post.data.tags.length > 0 && (
      <div class="tag-list" aria-label="文章标签">
        {post.data.tags.slice(0, 4).map((tag) => (
          <a href={withBase(`/tags/${tagToSlug(tag)}/`)}>#{tag}</a>
        ))}
      </div>
    )
  }
</article>
