---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import {
  formatDate,
  getCategory,
  getPostUrl,
  getPublishedPosts,
  groupPostsByYear
} from '../../utils/posts';
import { withBase } from '../../utils/site';

const groups = groupPostsByYear(getPublishedPosts(await getCollection('posts')));
---

<PageLayout
  title="文章归档"
  description="按发表年份回看知识积累的轨迹。"
  eyebrow="Chronological Atlas"
>
  {
    groups.map(([year, posts]) => (
      <section class="archive-year" aria-labelledby={`year-${year}`}>
        <h2 id={`year-${year}`}>{year}</h2>
        <ol class="archive-list">
          {posts.map((post) => (
            <li>
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate).slice(5)}
              </time>
              <a href={withBase(getPostUrl(post))}>{post.data.title}</a>
              <span>{getCategory(post.data.category).name}</span>
            </li>
          ))}
        </ol>
      </section>
    ))
  }
</PageLayout>
