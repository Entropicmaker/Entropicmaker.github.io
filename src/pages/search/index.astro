---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout
  title="搜索"
  description="搜索文章标题、摘要与正文。索引在构建时生成，查询完全在浏览器本地完成。"
  eyebrow="Local Static Search"
>
  <section class="search-panel" aria-label="站内搜索">
    <form class="search-form" id="search-form" role="search">
      <label class="sr-only" for="search-input">搜索关键词</label>
      <input
        id="search-input"
        name="q"
        type="search"
        placeholder="例如：空间自相关、Pandas、图算法"
        autocomplete="off"
      />
      <button class="button" type="submit">搜索</button>
    </form>
    <p class="search-status" id="search-status" aria-live="polite">输入关键词开始搜索。</p>
    <div class="search-results" id="search-results"></div>
  </section>
</PageLayout>

<script is:inline define:vars={{ base: import.meta.env.BASE_URL }}>
  const form = document.querySelector('#search-form');
  const input = document.querySelector('#search-input');
  const status = document.querySelector('#search-status');
  const container = document.querySelector('#search-results');

  const escapeHtml = (value) => {
    const element = document.createElement('span');
    element.textContent = value;
    return element.innerHTML;
  };

  const normalizeUrl = (url) => (url.startsWith(base) ? url : `${base}${url.replace(/^\/+/, '')}`);

  const runSearch = async (query) => {
    if (!query.trim()) {
      status.textContent = '输入关键词开始搜索。';
      container.innerHTML = '';
      return;
    }
    status.textContent = '正在检索本地索引…';
    try {
      const pagefind = await import(`${base}pagefind/pagefind.js`);
      const search = await pagefind.search(query);
      const results = await Promise.all(search.results.slice(0, 20).map((result) => result.data()));
      status.textContent = `找到 ${search.results.length} 条结果。`;
      container.innerHTML = results
        .map(
          (result) => `
        <article class="search-result">
          <h2><a href="${normalizeUrl(result.url)}">${escapeHtml(result.meta.title || '无标题')}</a></h2>
          <p>${result.excerpt}</p>
        </article>
      `
        )
        .join('');
    } catch (error) {
      status.textContent = '搜索索引仅在执行生产构建后可用。请先运行 npm run build。';
      container.innerHTML = '';
    }
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const query = input?.value || '';
    const url = new URL(window.location.href);
    url.searchParams.set('q', query);
    history.replaceState(null, '', url);
    runSearch(query);
  });

  const initial = new URLSearchParams(window.location.search).get('q') || '';
  if (input) input.value = initial;
  if (initial) runSearch(initial);
</script>
